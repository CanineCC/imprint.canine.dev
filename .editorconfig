root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{csproj,props,targets,slnx,json,yml,yaml}]
indent_size = 2

[*.{js,css,html,razor}]
indent_size = 2

[*.cs]
csharp_style_namespace_declarations = file_scoped:error
csharp_style_prefer_primary_constructors = true:suggestion
csharp_prefer_braces = when_multiline:suggestion
dotnet_sort_system_directives_first = true
# Tests run in-process against SQLite in-memory; threading a TestContext token through
# every call adds noise without adding safety at this scale.
dotnet_diagnostic.xUnit1051.severity = none

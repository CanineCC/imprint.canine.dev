@namespace Imprint.Publishing
@* The published document shell — the HTML contract (docs/publishing.md) in one
   template: one stylesheet link, the two sanctioned inline scripts (theme toggle in
   <head> before the stylesheet so an explicit choice applies at first paint; island
   loader at the end of <body> so it can see the islands), landmarks, skip link, nav
   with aria-current. The header/footer reproduce the marketing chrome (brand mark,
   grouped dropdown nav, quiet link + CTA, footer link columns + fine print) using
   imprint's own ip-* class names, which the marketing theme styles against. Every href
   and label is already resolved for this locale by the publisher; this stays a dumb
   template. The body carries .ip-page so the chrome inherits the site theme; PageView
   emits its own .ip-page wrapper, which nests harmlessly. *@
<html lang="@Chrome.Lang">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>@((MarkupString)HtmlText.Encode(Chrome.Title))</title>
  @if (Chrome.MetaDescription is not null)
  {
    <meta name="description" content="@Chrome.MetaDescription" />
  }
  @if (Chrome.CanonicalHref is not null)
  {
    <link rel="canonical" href="@Chrome.CanonicalHref" />
  }
  @foreach (var alternate in Chrome.Alternates)
  {
    <link rel="alternate" hreflang="@alternate.Hreflang" href="@alternate.Href" />
  }
  <script>@((MarkupString)PublisherScripts.ThemeToggle)</script>
  <link rel="stylesheet" href="@Chrome.StylesheetHref" />
</head>
<body class="ip-page">
  <a href="#main">Skip to content</a>
  <header class="ip-site-header">
    <a class="ip-brand" href="@Chrome.HomeHref"><span class="ip-brand-dot" aria-hidden="true"></span>@Chrome.SiteName</a>
    <nav class="ip-nav" aria-label="Main">
      <ul>
        @foreach (var item in Chrome.Nav)
        {
          @if (item.IsGroup)
          {
            <li class="ip-nav-group">
              <button type="button" class="ip-nav-trigger" aria-haspopup="true">@item.Label</button>
              <div class="ip-nav-panel">
                @foreach (var child in item.Children)
                {
                  <a class="ip-nav-card" href="@child.Href" aria-current="@(child.IsCurrent ? "page" : null)">
                    <strong>@child.Label</strong>
                    @if (child.Description is not null)
                    {
                      <span>@child.Description</span>
                    }
                  </a>
                }
              </div>
            </li>
          }
          else
          {
            <li><a href="@item.Href" aria-current="@(item.IsCurrent ? "page" : null)">@item.Label</a></li>
          }
        }
      </ul>
    </nav>
    <div class="ip-header-actions">
      @{
        // Real locales only (drop the x-default SEO alias). A switcher appears solely on
        // multilingual sites — one locale means nothing to switch to, so it stays hidden.
        var localeLinks = Chrome.Alternates.Where(a => a.Hreflang != "x-default").ToList();
      }
      @if (localeLinks.Count > 1)
      {
        <nav class="ip-lang" aria-label="Language">
          @foreach (var loc in localeLinks)
          {
            var isCurrent = string.Equals(loc.Hreflang, Chrome.Lang, StringComparison.OrdinalIgnoreCase);
            <a href="@loc.Href" hreflang="@loc.Hreflang" lang="@loc.Hreflang"
               aria-current="@(isCurrent ? "true" : null)">@loc.Hreflang.ToUpperInvariant()</a>
          }
        </nav>
      }
      @if (Chrome.HeaderQuiet is not null)
      {
        <a class="ip-header-quiet" href="@Chrome.HeaderQuiet.Href">@Chrome.HeaderQuiet.Label</a>
      }
      @if (Chrome.HeaderCta is not null)
      {
        <a class="ip-header-cta" href="@Chrome.HeaderCta.Href">@Chrome.HeaderCta.Label</a>
      }
      <button type="button" data-theme-toggle aria-label="Switch color theme">◐</button>
    </div>
  </header>
  <main id="main">
    @if (Content is not null)
    {
      @Content
    }
    else
    {
      <CascadingValue Value="@Ctx">
        <PageView Roots="@Roots" />
      </CascadingValue>
    }
  </main>
  <footer class="ip-site-footer">
    @if (Chrome.FooterGroups.Count > 0)
    {
      <div class="ip-footer-cols">
        @foreach (var group in Chrome.FooterGroups)
        {
          <nav class="ip-footer-group" aria-label="@group.Heading">
            <span class="ip-footer-h">@group.Heading</span>
            @foreach (var link in group.Links)
            {
              <a href="@link.Href">@link.Label</a>
            }
          </nav>
        }
      </div>
    }
    <div class="ip-footer-fine">
      <span class="ip-footer-brand"><span class="ip-brand-dot" aria-hidden="true"></span>@Chrome.SiteName</span>
      <span class="ip-footer-byline">by <a href="https://canine.dev">Canine Development</a></span>
      @if (Chrome.CopyLine is not null)
      {
        <p class="ip-footer-copy">@Chrome.CopyLine</p>
      }
    </div>
  </footer>
  @if (Chrome.IncludeIslandLoader)
  {
    <script>@((MarkupString)PublisherScripts.IslandLoader)</script>
  }
</body>
</html>

@code {
  [Parameter, EditorRequired] public StaticPageChrome Chrome { get; set; } = default!;

  /// <summary>The static-mode render context cascaded to the node views. Required unless <see cref="Content"/> is set.</summary>
  [Parameter] public RenderContext? Ctx { get; set; }

  [Parameter] public IReadOnlyList<Node> Roots { get; set; } = [];

  /// <summary>Replaces the PageView body — used by the 404 page, which has no node tree.</summary>
  [Parameter] public RenderFragment? Content { get; set; }
}

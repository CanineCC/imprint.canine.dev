@namespace Imprint.Rendering
@using Microsoft.AspNetCore.Components.Rendering
@inherits NodeViewBase<WidgetNode>
@{
  var descriptor = Ctx.ResolveWidget(Node.Tag);
}
@if (IsEditor)
{
  @* The canvas renders the REAL island when the editor can serve its bundle (all
     shipped widgets are shadow-DOM components, so a hydrated one never mutates the
     light DOM Blazor owns). NodeAttributes on the host keep it selectable. The
     placeholder remains the honest fallback: unknown tag, or no bundle to serve. *@
  if (descriptor is not null && Ctx.ResolveWidgetBundle?.Invoke(descriptor.Tag) is not null)
  {
    RenderIsland(__builder, descriptor, editorAttributes: true);
  }
  else if (descriptor is not null)
  {
    <div class="ip-widget-placeholder" @attributes="NodeAttributes">@descriptor.Name</div>
  }
  else
  {
    <div class="ip-widget-placeholder ip-placeholder-warn" @attributes="NodeAttributes">Unknown widget @Node.Tag</div>
  }
}
else if (descriptor is not null)
{
  RenderIsland(__builder, descriptor);
}
@* Static + unknown tag: nothing. There is no bundle to load, so a dead custom element
   would ship broken markup to every visitor; the editor placeholder is where the
   problem gets surfaced and fixed. *@

@code {
  private void RenderIsland(RenderTreeBuilder builder, WidgetDescriptor descriptor, bool editorAttributes = false)
  {
    // Tag came from the manifest loader, which enforces lower-case-ASCII-with-hyphen —
    // that validation is what makes emitting it as an element name safe.
    builder.OpenElement(0, descriptor.Tag);

    // Editor canvas only: the selection contract (data-node-id/type) rides the host
    // element, exactly like every other node's root.
    if (editorAttributes)
    {
      builder.AddMultipleAttributes(6, NodeAttributes);
    }

    // Attribute allowlist: only props the manifest declares cross into markup, so a
    // stale PropBag entry (or a malicious one) never becomes an attribute.
    foreach (var prop in descriptor.Props)
    {
      // Last gate before markup: a prop name that isn't a plain data attribute — an on*
      // event handler or `style` — must NEVER be emitted with an author-controlled value,
      // or it becomes a live event handler / inline style on every visitor's page (stored
      // XSS / CSS injection). Submission validation and the manifest loader already reject
      // these; this re-checks at the one point every widget attribute passes through, so a
      // hand-edited event stream or manifest cannot slip one past. Mirrors SvgPublishGuard.
      if (!WidgetManifest.IsValidPropName(prop.Name))
      {
        continue;
      }

      if (Node.Props.Get(prop.Name) is { } value)
      {
        builder.AddAttribute(1, prop.Name, value);
      }
    }

    if (Ctx.ResolveWidgetBundle?.Invoke(descriptor.Tag) is { } bundle)
    {
      builder.AddAttribute(2, "data-island", bundle);
    }

    if (descriptor.Eager)
    {
      builder.AddAttribute(3, "data-island-eager", true);
    }

    // aspect-ratio reserves the box before hydration (zero CLS). The manifest is
    // repo-controlled but still data: the character allowlist keeps the inline style
    // a ratio and nothing else.
    if (descriptor.AspectRatio is { Length: > 0 } aspect && aspect.All(c => char.IsAsciiDigit(c) || c is ' ' or '/' or '.'))
    {
      builder.AddAttribute(4, "style", $"aspect-ratio: {aspect}");
    }

    builder.AddContent(5, descriptor.Placeholder);
    builder.CloseElement();
  }
}

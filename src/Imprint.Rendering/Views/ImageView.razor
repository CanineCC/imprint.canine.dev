@namespace Imprint.Rendering
@using Imprint.Authoring.Domain.Assets
@using Microsoft.AspNetCore.Components.Rendering
@inherits NodeViewBase<ImageNode>
@{
  RenderImage(__builder);
}

@code {
  [CascadingParameter] public PageRenderState? PageState { get; set; }

  private void RenderImage(RenderTreeBuilder builder)
  {
    var info = Node.AssetId is { } assetId ? Ctx.ResolveAsset(assetId) : null;
    if (info is not { Kind: AssetKind.Image } || info.ImageVariants.Count == 0)
    {
      // Static: an unpublishable image renders nothing — a broken <img> on a visitor's
      // page is worse than absence. The editor shows what is missing instead.
      if (IsEditor)
      {
        RenderPlaceholder(builder);
      }

      return;
    }

    var light = info.ImageVariants.OrderBy(v => v.Width).ToList();
    var dark = info.DarkImageVariants.OrderBy(v => v.Width).ToList();
    // One claim per image node, whichever renditions it emits: the light copy is the
    // one that paints in the default (light) scheme, so it carries the LCP priority.
    var eager = PageState?.TryClaimFirstImage() == true;

    if (info.HasDark && dark.Count > 0)
    {
      // Both renditions ship; CSS (imprint-base.css) shows exactly one by colour scheme
      // with zero JavaScript. The dark copy is aria-hidden and drops the alt so assistive
      // tech announces the image once, from the light copy.
      RenderRendition(builder, seq: 0, info, light, "ip-img-light", isDark: false, eager);
      RenderRendition(builder, seq: 20, info, dark, "ip-img-dark", isDark: true, eager: false);
      return;
    }

    // Neutral asset: a single image, unchanged.
    RenderRendition(builder, seq: 0, info, light, variantClass: null, isDark: false, eager);
  }

  private void RenderRendition(
    RenderTreeBuilder builder, int seq, AssetRenderInfo info,
    IReadOnlyList<ImageSource> sources, string? variantClass, bool isDark, bool eager)
  {
    // Middle variant as src: the fallback for pre-srcset consumers (readers, scrapers)
    // should be a reasonable size, not the largest download.
    var src = sources[(sources.Count - 1) / 2];
    var largest = sources[^1];

    builder.OpenElement(seq, "img");
    builder.AddAttribute(seq + 1, "class", Classes("ip-img", variantClass, AspectClass, RoundedClass));
    builder.AddAttribute(seq + 2, "src", src.Url);
    builder.AddAttribute(seq + 3, "srcset", string.Join(", ", sources.Select(v => $"{v.Url} {v.Width}w")));
    builder.AddAttribute(seq + 4, "sizes", CurrentHints.ToSizesAttribute());
    // Intrinsic dimensions from the largest variant: the browser reserves the box
    // before any bytes arrive — zero CLS by construction.
    builder.AddAttribute(seq + 5, "width", largest.Width.ToString());
    builder.AddAttribute(seq + 6, "height", largest.Height.ToString());
    if (isDark)
    {
      builder.AddAttribute(seq + 7, "aria-hidden", "true");
    }
    else
    {
      builder.AddAttribute(seq + 7, "alt", AltText(info));
    }

    if (eager)
    {
      builder.AddAttribute(seq + 8, "loading", "eager");
      builder.AddAttribute(seq + 9, "fetchpriority", "high");
    }
    else
    {
      builder.AddAttribute(seq + 10, "loading", "lazy");
    }

    builder.AddAttribute(seq + 11, "decoding", "async");
    // The editor-selection attributes ride the light (primary) rendition only, so the
    // canvas has one hit-target per node and the DOM one data-node-id.
    if (!isDark)
    {
      builder.AddMultipleAttributes(seq + 12, NodeAttributes);
    }

    builder.CloseElement();
  }

  private void RenderPlaceholder(RenderTreeBuilder builder)
  {
    builder.OpenElement(0, "div");
    // Aspect classes on the placeholder too, so the canvas approximates the final box.
    builder.AddAttribute(1, "class", Classes("ip-placeholder", AspectClass, RoundedClass));
    builder.AddMultipleAttributes(2, NodeAttributes);
    builder.AddContent(3, Node.DisplayName);
    builder.CloseElement();
  }

  private string AltText(AssetRenderInfo info)
  {
    var alt = Resolve(Node.Alt);
    return alt.Length > 0 ? alt : Resolve(info.DefaultAlt);
  }

  private string? AspectClass => Node.Aspect switch
  {
    ImageAspect.Square => "ip-img-square",
    ImageAspect.Wide16x9 => "ip-img-wide16x9",
    ImageAspect.Portrait3x4 => "ip-img-portrait3x4",
    _ => null,
  };

  private string? RoundedClass => Node.Rounded ? "ip-img-rounded" : null;
}

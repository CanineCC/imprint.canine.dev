@namespace Imprint.Rendering
@using Microsoft.AspNetCore.Components.Rendering
@inherits NodeViewBase<HeadingNode>
@{
  RenderHeading(__builder);
}

@code {
  // The tag name (h1–h4) is data-driven, which markup syntax cannot express — this is
  // the one view built directly against the render tree.
  private void RenderHeading(RenderTreeBuilder builder)
  {
    builder.OpenElement(0, $"h{Math.Clamp(Node.Level, 1, 4)}");
    builder.AddMultipleAttributes(1, NodeAttributes);
    builder.AddContent(2, Resolve(Node.Text));
    builder.CloseElement();
  }
}

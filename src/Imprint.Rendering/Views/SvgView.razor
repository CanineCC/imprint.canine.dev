@namespace Imprint.Rendering
@inherits NodeViewBase<SvgNode>
@{
  var info = Node.AssetId is { } assetId ? Ctx.ResolveAsset(assetId) : null;
}
@if (info?.InlineSvg is { } svg)
{
  @* Inlined (sanitized at ingest) so strokes and fills inherit currentColor and
     follow the theme — an <img src=…svg> would be locked to its authored colors. *@
  @if (info.DarkInlineSvg is { } darkSvg)
  {
    @* Both renditions inline; CSS (imprint-base.css) reveals exactly one by colour
       scheme, zero JS. The dark copy is aria-hidden and unnamed so assistive tech
       announces the graphic once, from the light copy. *@
    <div class="ip-svg ip-img-light" @attributes="SvgAttributes(info, isDark: false)">@((MarkupString)svg)</div>
    <div class="ip-svg ip-img-dark" @attributes="SvgAttributes(info, isDark: true)">@((MarkupString)darkSvg)</div>
  }
  else
  {
    <div class="ip-svg" @attributes="SvgAttributes(info, isDark: false)">@((MarkupString)svg)</div>
  }
}
else if (IsEditor)
{
  <div class="ip-placeholder" @attributes="NodeAttributes">@Node.DisplayName</div>
}

@code {
  private IReadOnlyDictionary<string, object> SvgAttributes(AssetRenderInfo info, bool isDark)
  {
    var attributes = new Dictionary<string, object>();

    if (isDark)
    {
      // The light copy carries the accessible name and the node id; the dark mirror is
      // hidden from assistive tech and is not an editor hit-target.
      attributes["aria-hidden"] = "true";
    }
    else
    {
      var alt = Resolve(Node.Alt);
      if (alt.Length == 0)
      {
        alt = Resolve(info.DefaultAlt);
      }

      // Meaningful graphics get an accessible name; unnamed ones are decorative and
      // must be hidden from assistive tech rather than announced as "image".
      if (alt.Length > 0)
      {
        attributes["role"] = "img";
        attributes["aria-label"] = alt;
      }
      else
      {
        attributes["aria-hidden"] = "true";
      }
    }

    if (Node.MaxWidthPx is { } maxWidth)
    {
      attributes["style"] = $"max-width: {maxWidth}px";
    }

    if (!isDark)
    {
      foreach (var (name, value) in NodeAttributes)
      {
        attributes[name] = value;
      }
    }

    return attributes;
  }
}

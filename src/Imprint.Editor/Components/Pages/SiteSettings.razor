    private async Task SaveEnvs()
    {
        if (_site is not { } site)
        {
            return;
        }

        var environments = _envs
            .Select(e => new DeployEnvironment(
                e.Name.Trim(),
                e.Path.Trim(),
                e.BaseUrl.Trim() is { Length: > 0 } baseUrl ? baseUrl : null))
            .ToList();

        if (await Commands.Run(new ConfigureEnvironments(site.Id, environments)))
        {
            // Re-seed from the saved state so the dirty flag clears and normalization shows.
            _site = Sites.Get(site.Id);
            SeedEnvs();
            Toasts.Show("Publish folders saved.");
        }
    }

    private async Task PublishTo(string environment)
    {
        if (_busy || _site is not { } site)
        {
            return; // _busy guards re-entrancy in code, not just via the disabled attribute
        }

        _busy = true;
        try
        {
            var report = await Deploy.PublishToEnvironment(site.Id, environment);
            Toasts.Show($"Published to {environment}: {report.PagesRendered} rendered, {report.FilesWritten} files written.");
        }
        catch (Exception e)
        {
            Toasts.Error($"Could not publish to {environment}: {e.Message}");
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Promote(string from, string to)
    {
        if (_busy || _site is not { } site)
        {
            return; // _busy guards re-entrancy in code, not just via the disabled attribute
        }

        _busy = true;
        try
        {
            await Deploy.Promote(site.Id, from, to);
            Toasts.Show($"Promoted {from} → {to}.");
        }
        catch (Exception e)
        {
            Toasts.Error($"Could not promote {from} → {to}: {e.Message}");
        }
        finally
        {
            _busy = false;
        }
    }

    private static string StateClass(EnvironmentDeployStatus status) =>
        status.Error is not null ? "is-error" : status.Deployed ? "is-live" : "is-idle";

    private static string StateText(EnvironmentDeployStatus status) =>
        status.Error is { } error ? $"⚠ {error}"
        : status.Deployed ? $"Published · {status.PageCount} {(status.PageCount == 1 ? "page" : "pages")} · site v{status.SiteVersion}"
        : "Not published";

    private static bool TryParse(string value, out SiteId id)
    {
        if (Guid.TryParseExact(value, "N", out var guid) || Guid.TryParse(value, out guid))
        {
            id = SiteId.From(guid);
            return true;
        }

        id = default;
        return false;
    }

    public void Dispose() => Sites.Changed -= OnSitesChanged;
}

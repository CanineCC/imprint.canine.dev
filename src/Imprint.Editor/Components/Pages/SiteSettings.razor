@page "/sites/{SiteIdValue}/settings"
@using Imprint.Authoring.Domain
@using Imprint.Authoring.Domain.Sites
@using Imprint.Authoring.Projections
@using Imprint.Authoring.Domain.Pages
@using Imprint.Authoring.Features.Sites.RenameSite
@using Imprint.Authoring.Features.Sites.ConfigureEnvironments
@using Imprint.Authoring.Features.Sites.AddCollaborator
@using Imprint.Authoring.Features.Sites.ChangeNavigation
@using Imprint.Authoring.Features.Sites.ClaimSite
@using Imprint.Authoring.Features.Sites.RemoveCollaborator
@using Imprint.Authoring.Features.Sites.SetCopyLine
@using Imprint.Authoring.Features.Sites.SetFooter
@using Imprint.Authoring.Features.Sites.SetHeaderActions
@using Imprint.Editor.Auth
@using Imprint.Editor.Services
@using Imprint.Publishing
@implements IDisposable
@inject SiteOverview Sites
@inject SiteAccess Access
@inject PageList Pages
@inject PublishedContent Published
@inject CommandRunner Commands
@inject SiteDeployService Deploy
@inject ToastService Toasts
@inject NavigationManager Navigation

<PageTitle>@(_site?.Name ?? "Site") · Settings</PageTitle>

<div class="settings">
    <header class="settings-head">
        <a class="dash-back" href="/">← All sites</a>
    </header>

    @if (_site is not { } site || !_canAccess)
    {
        <section class="settings-card">
            <p class="panel-empty">This site could not be found. <a href="/">Back to your sites.</a></p>
        </section>
    }
    else
    {
        <div class="settings-title">
            <h1>@site.Name</h1>
            <a class="ed-btn" href="@OpenHref(site.Id)">Open editor →</a>
        </div>

        @* ---- Name (owner-only: site identity is administration, not content) ---- *@
        @if (_isOwner)
        {
            <section class="settings-card" aria-labelledby="set-name">
                <h2 id="set-name">Name</h2>
                <div class="settings-row">
                    <input class="ed-input" aria-label="Site name" disabled="@(!_interactive)" @bind="_name" @bind:event="oninput" />
                    <button type="button" class="ed-btn ed-btn-primary"
                            disabled="@(!_interactive || _name.Trim().Length == 0 || _name.Trim() == site.Name)"
                            @onclick="SaveName">Save name</button>
                </div>
            </section>
        }

        @* ---- Header & footer (marketing chrome) ---- *@
        <section class="settings-card" aria-labelledby="set-chrome">
            <h2 id="set-chrome">Header &amp; footer</h2>
            <p class="settings-hint">
                The navigation menu itself is managed in the editor's <strong>Pages</strong> panel
                (drag pages into or out of the navigation; the first is the home page). Here you
                maintain the rest of the chrome: the header's action buttons, the footer's link
                columns, and the fine-print copy line. A link is a full URL
                (<code>https://…</code>) or a same-site page as <code>page://slug</code>.
            </p>

            <h3 class="chrome-heading">Navigation menu</h3>
            <p class="settings-hint">
                Top-to-bottom here is left-to-right in the header. The <strong>first page
                entry is the home page</strong> (it renders at <code>/</code>). Leave the
                target empty and add sub-links to make a dropdown group.
            </p>
            <datalist id="nav-page-options">
                @foreach (var pageOption in Pages.All(site.Id))
                {
                    <option value="@($"page://{pageOption.Slug.Value}")">@pageOption.Title.Resolve(ChromeLocale, ChromeLocale)</option>
                }
            </datalist>
            @foreach (var item in _navItems)
            {
                var idx = _navItems.IndexOf(item);
                <div class="chrome-group" @key="item">
                    <div class="chrome-row">
                        <input class="ed-input chrome-label" placeholder="Label (empty = page title)" aria-label="Menu entry label"
                               disabled="@(!_interactive)" @bind="item.Label" @bind:event="oninput" />
                        <input class="ed-input chrome-url" list="nav-page-options"
                               placeholder="page://slug or https://… (empty = dropdown group)" aria-label="Menu entry target"
                               disabled="@(!_interactive || item.Children.Count > 0)" @bind="item.Url" @bind:event="oninput" />
                        <button type="button" class="ed-btn ed-btn-ghost" title="Move up" aria-label="Move menu entry up"
                                disabled="@(!_interactive || idx == 0)" @onclick="() => MoveNavItem(idx, -1)">↑</button>
                        <button type="button" class="ed-btn ed-btn-ghost" title="Move down" aria-label="Move menu entry down"
                                disabled="@(!_interactive || idx == _navItems.Count - 1)" @onclick="() => MoveNavItem(idx, 1)">↓</button>
                        <button type="button" class="ed-btn ed-btn-ghost ed-btn-danger" title="Remove entry"
                                aria-label="Remove menu entry" disabled="@(!_interactive)"
                                @onclick="() => _navItems.Remove(item)">✕</button>
                    </div>
                    @foreach (var child in item.Children)
                    {
                        <div class="chrome-row chrome-link" @key="child">
                            <input class="ed-input chrome-label" placeholder="Label (empty = page title)" aria-label="Sub-link label"
                                   disabled="@(!_interactive)" @bind="child.Label" @bind:event="oninput" />
                            <input class="ed-input chrome-url" list="nav-page-options" placeholder="page://slug or https://…"
                                   aria-label="Sub-link target" disabled="@(!_interactive)" @bind="child.Url" @bind:event="oninput" />
                            <input class="ed-input chrome-label" placeholder="Description (optional)" aria-label="Sub-link description"
                                   disabled="@(!_interactive)" @bind="child.Description" @bind:event="oninput" />
                            <button type="button" class="ed-btn ed-btn-ghost ed-btn-danger" title="Remove sub-link"
                                    aria-label="Remove sub-link" disabled="@(!_interactive)"
                                    @onclick="() => item.Children.Remove(child)">✕</button>
                        </div>
                    }
                    <button type="button" class="ed-btn ed-btn-ghost chrome-add-link"
                            disabled="@(!_interactive || item.Children.Count >= Site.MaxNavigationChildren)"
                            @onclick="() => item.Children.Add(new NavChildEdit())">＋ Add sub-link (makes this a dropdown)</button>
                </div>
            }
            <div class="settings-row">
                <button type="button" class="ed-btn"
                        disabled="@(!_interactive || _navItems.Count >= Site.MaxNavigationItems)"
                        @onclick="() => _navItems.Add(new NavItemEdit())">＋ Add menu entry</button>
                <button type="button" class="ed-btn ed-btn-primary" disabled="@(!_interactive || _busy)"
                        @onclick="SaveNavigation">Save navigation</button>
            </div>

            <h3 class="chrome-heading">Header actions</h3>
            <div class="chrome-row">
                <span class="chrome-kind">Primary button</span>
                <input class="ed-input chrome-label" placeholder="Label (empty = none)" aria-label="Primary button label"
                       disabled="@(!_interactive)" @bind="_cta.Label" @bind:event="oninput" />
                <input class="ed-input chrome-url" placeholder="https://… or page://slug" aria-label="Primary button link"
                       disabled="@(!_interactive)" @bind="_cta.Url" @bind:event="oninput" />
            </div>
            <div class="chrome-row">
                <span class="chrome-kind">Quiet link</span>
                <input class="ed-input chrome-label" placeholder="Label (empty = none)" aria-label="Quiet link label"
                       disabled="@(!_interactive)" @bind="_quiet.Label" @bind:event="oninput" />
                <input class="ed-input chrome-url" placeholder="https://… or page://slug" aria-label="Quiet link target"
                       disabled="@(!_interactive)" @bind="_quiet.Url" @bind:event="oninput" />
            </div>
            <div class="settings-row">
                <button type="button" class="ed-btn ed-btn-primary" disabled="@(!_interactive || _busy)"
                        @onclick="SaveHeader">Save header</button>
            </div>

            <h3 class="chrome-heading">Footer link columns</h3>
            @if (_footerGroups.Count == 0)
            {
                <p class="panel-empty">No footer columns yet. Add one below.</p>
            }
            @foreach (var group in _footerGroups)
            {
                <div class="chrome-group" @key="group">
                    <div class="chrome-row">
                        <input class="ed-input chrome-label" placeholder="Column heading" aria-label="Footer column heading"
                               disabled="@(!_interactive)" @bind="group.Heading" @bind:event="oninput" />
                        <button type="button" class="ed-btn ed-btn-ghost ed-btn-danger" title="Remove column"
                                aria-label="Remove footer column" disabled="@(!_interactive)"
                                @onclick="() => _footerGroups.Remove(group)">✕</button>
                    </div>
                    @foreach (var link in group.Links)
                    {
                        <div class="chrome-row chrome-link" @key="link">
                            <input class="ed-input chrome-label" placeholder="Label (empty = page title)" aria-label="Footer link label"
                                   disabled="@(!_interactive)" @bind="link.Label" @bind:event="oninput" />
                            <input class="ed-input chrome-url" placeholder="https://… or page://slug" aria-label="Footer link target"
                                   disabled="@(!_interactive)" @bind="link.Url" @bind:event="oninput" />
                            <button type="button" class="ed-btn ed-btn-ghost ed-btn-danger" title="Remove link"
                                    aria-label="Remove footer link" disabled="@(!_interactive)"
                                    @onclick="() => group.Links.Remove(link)">✕</button>
                        </div>
                    }
                    <button type="button" class="ed-btn ed-btn-ghost chrome-add-link"
                            disabled="@(!_interactive || group.Links.Count >= Site.MaxFooterLinksPerGroup)"
                            @onclick="() => group.Links.Add(new FooterLinkEdit())">＋ Add link</button>
                </div>
            }
            <div class="settings-row">
                <button type="button" class="ed-btn"
                        disabled="@(!_interactive || _footerGroups.Count >= Site.MaxFooterGroups)"
                        @onclick="() => _footerGroups.Add(new FooterGroupEdit())">＋ Add column</button>
                <button type="button" class="ed-btn ed-btn-primary" disabled="@(!_interactive || _busy)"
                        @onclick="SaveFooter">Save footer</button>
            </div>

            <h3 class="chrome-heading">Copy line</h3>
            <div class="settings-row">
                <input class="ed-input chrome-copy" placeholder="© 2026 · Your fine print (empty = none)"
                       aria-label="Footer copy line" disabled="@(!_interactive)" @bind="_copyLine" @bind:event="oninput" />
                <button type="button" class="ed-btn ed-btn-primary" disabled="@(!_interactive || _busy)"
                        @onclick="SaveCopyLine">Save copy line</button>
            </div>
        </section>

        @* ---- People (owner + collaborators) ---- *@
        <section class="settings-card" aria-labelledby="set-people">
            <h2 id="set-people">People</h2>
            <p class="settings-hint">
                The owner and everyone listed here can open, edit and publish this site.
                Access follows the email a person signs in with.
                @if (!Access.Enforced)
                {
                    <text> Sign-in is not enabled on this install, so the list is kept but not enforced yet.</text>
                }
            </p>

            <ul class="people-list">
                <li class="people-row">
                    @if (Sites.IsUnclaimed(site.Id))
                    {
                        <span class="people-email">
                            Unclaimed — created before sign-in@(Sites.OwnerOf(site.Id) is { Length: > 0 } legacy ? $" (as '{legacy}')" : "").
                            Visible to every signed-in user until someone takes ownership.
                        </span>
                        @if (Access.Enforced && _user is { Length: > 0 })
                        {
                            <button type="button" class="ed-btn ed-btn-primary" disabled="@(!_interactive || _busy)"
                                    @onclick="TakeOwnership">Take ownership</button>
                        }
                    }
                    else
                    {
                        <span class="people-email">@Sites.OwnerOf(site.Id)</span>
                        <span class="people-role">Owner</span>
                    }
                </li>
                @foreach (var collaborator in site.Collaborators)
                {
                    <li class="people-row" @key="collaborator">
                        <span class="people-email">@collaborator</span>
                        <span class="people-role">Editor</span>
                        @if (_isOwner)
                        {
                            <button type="button" class="ed-btn ed-btn-ghost ed-btn-danger" title="Remove access"
                                    aria-label="@($"Remove {collaborator}")"
                                    disabled="@(!_interactive || _busy)" @onclick="() => RemovePerson(collaborator)">✕</button>
                        }
                    </li>
                }
            </ul>

            @if (_isOwner)
            {
                <div class="settings-row">
                    <input class="ed-input" type="email" placeholder="colleague@example.com"
                           aria-label="Email of the person to add" disabled="@(!_interactive || _busy)"
                           @bind="_newPerson" @bind:event="oninput"
                           @onkeydown="@(e => e.Key == "Enter" ? AddPerson() : Task.CompletedTask)" />
                    <button type="button" class="ed-btn ed-btn-primary"
                            disabled="@(!_interactive || _busy || _newPerson.Trim().Length == 0)"
                            @onclick="AddPerson">Add editor</button>
                </div>
            }
            else
            {
                <p class="settings-hint">Only the site's owner can add or remove people.</p>
            }
        </section>

        @* ---- Publish folders + deploy (owner-only: where bytes land is administration) ---- *@
        @if (_isOwner)
        {
        @* ---- Publish folders (deploy environments) ---- *@
        <section class="settings-card" aria-labelledby="set-envs">
            <h2 id="set-envs">Publish folders</h2>
            <p class="settings-hint">
                Each environment is a folder Imprint writes the finished static site into.
                The <strong>first</strong> is where your published pages go automatically; the rest you
                <em>promote</em> to, in order — so you can verify on Test before it reaches Production.
                The optional <em>site address</em> is the environment's public origin (like
                <code>https://example.com</code>): when set, canonical links, the sitemap and robots.txt
                are written as absolute URLs against it; left blank, they stay root-relative.
            </p>

            @if (_envs.Count == 0)
            {
                <p class="panel-empty">No publish folders yet. Add one below.</p>
            }
            else
            {
                <ol class="env-list">
                    @for (var i = 0; i < _envs.Count; i++)
                    {
                        var idx = i;
                        @* @key ties browser state (focus/caret/selection) to the logical
                           row, so reordering/removing moves the DOM node instead of
                           re-labelling whichever node sits at that position. *@
                        <li class="env-row" @key="_envs[idx]">
                            <span class="env-order" aria-hidden="true">@(idx + 1)</span>
                            <input class="ed-input env-name" placeholder="Test" aria-label="Environment name"
                                   disabled="@(!_interactive)" @bind="_envs[idx].Name" @bind:event="oninput" />
                            <input class="ed-input env-path" placeholder="/var/www/my-site/test" aria-label="Publish folder"
                                   disabled="@(!_interactive)" @bind="_envs[idx].Path" @bind:event="oninput" />
                            <input class="ed-input env-baseurl" placeholder="https://example.com (optional)" aria-label="Site address"
                                   disabled="@(!_interactive)" @bind="_envs[idx].BaseUrl" @bind:event="oninput" />
                            <button type="button" class="ed-btn ed-btn-ghost" title="Move up" aria-label="Move up"
                                    disabled="@(!_interactive || idx == 0)" @onclick="() => MoveEnv(idx, -1)">↑</button>
                            <button type="button" class="ed-btn ed-btn-ghost" title="Move down" aria-label="Move down"
                                    disabled="@(!_interactive || idx == _envs.Count - 1)" @onclick="() => MoveEnv(idx, 1)">↓</button>
                            <button type="button" class="ed-btn ed-btn-ghost ed-btn-danger" title="Remove" aria-label="Remove environment"
                                    disabled="@(!_interactive)" @onclick="() => RemoveEnv(idx)">✕</button>
                        </li>
                    }
                </ol>
            }

            <div class="settings-row">
                <button type="button" class="ed-btn"
                        disabled="@(!_interactive || _envs.Count >= Site.MaxEnvironments)" @onclick="AddEnv">＋ Add environment</button>
                <button type="button" class="ed-btn ed-btn-primary"
                        disabled="@(!_interactive || !EnvsDirty)" @onclick="SaveEnvs">Save publish folders</button>
                @if (EnvsDirty)
                {
                    <span class="settings-dirty">Unsaved changes</span>
                }
            </div>
        </section>

        @* ---- Publish & promote ---- *@
        <section class="settings-card" aria-labelledby="set-deploy">
            <h2 id="set-deploy">Publish &amp; promote</h2>

            @if (site.Environments.Count == 0)
            {
                <p class="settings-hint">Add and save a publish folder above to deploy this site.</p>
            }
            else
            {
                @if (PublishedCount == 0)
                {
                    <p class="settings-hint settings-warn">
                        Nothing is published yet. Open the editor and publish your pages first — deploying now
                        would write an empty site.
                    </p>
                }

                <ol class="deploy-list">
                    @{ var statuses = Deploy.StatusOf(site.Id); }
                    @for (var i = 0; i < statuses.Count; i++)
                    {
                        var status = statuses[i];
                        var idx = i;
                        <li class="deploy-row">
                            <div class="deploy-head">
                                <span class="deploy-name">@status.Name</span>
                                <span class="deploy-state @StateClass(status)">@StateText(status)</span>
                            </div>
                            <div class="deploy-path" title="@status.ResolvedPath">@status.ConfiguredPath</div>
                            <div class="deploy-actions">
                                <button type="button" class="ed-btn ed-btn-primary"
                                        disabled="@_busy" @onclick="() => PublishTo(status.Name)">
                                    Publish to @status.Name
                                </button>
                                @if (idx > 0)
                                {
                                    var previous = statuses[idx - 1].Name;
                                    <button type="button" class="ed-btn" disabled="@_busy"
                                            @onclick="() => Promote(previous, status.Name)">
                                        Promote @previous → @status.Name
                                    </button>
                                }
                            </div>
                        </li>
                    }
                </ol>
            }
        </section>
        }
    }
</div>

@code {
    [Parameter] public string SiteIdValue { get; set; } = "";

    private sealed class EnvRow
    {
        public string Name { get; set; } = "";
        public string Path { get; set; } = "";
        public string BaseUrl { get; set; } = "";
    }

    private sealed class NavChildEdit
    {
        public string Label { get; set; } = "";
        public string Url { get; set; } = "";
        public string Description { get; set; } = "";
        public LocalizedText? OriginalLabel;
        public LocalizedText? OriginalDescription;
        public Link? OriginalLink;
        public string OriginalUrl = "";
    }

    private sealed class NavItemEdit
    {
        public string Label { get; set; } = "";
        public string Url { get; set; } = "";
        public LocalizedText? OriginalLabel;
        public Link? OriginalLink;
        public string OriginalUrl = "";
        public List<NavChildEdit> Children { get; } = [];
    }

    // Chrome edit rows. Originals are kept so an untouched value round-trips unchanged:
    // other-locale label texts survive via LocalizedText.With, and an untouched link
    // keeps its exact Link (a PageLink is not silently rewritten as an external URL).
    private sealed class ActionEdit
    {
        public string Label { get; set; } = "";
        public string Url { get; set; } = "";
        public LocalizedText? OriginalLabel;
        public Link? OriginalLink;
        public string OriginalUrl = "";
    }

    private sealed class FooterLinkEdit
    {
        public string Label { get; set; } = "";
        public string Url { get; set; } = "";
        public LocalizedText? OriginalLabel;
        public Link? OriginalLink;
        public string OriginalUrl = "";
    }

    private sealed class FooterGroupEdit
    {
        public string Heading { get; set; } = "";
        public LocalizedText? OriginalHeading;
        public List<FooterLinkEdit> Links { get; } = [];
    }

    private Site? _site;
    private SiteId? _loadedId;
    private string _name = "";
    private string _newPerson = "";
    private string? _user;
    private readonly List<EnvRow> _envs = [];
    private bool _interactive;
    private bool _busy;
    private bool _canAccess;
    private bool _isOwner;

    protected override void OnInitialized() => Sites.Changed += OnSitesChanged;

    protected override async Task OnParametersSetAsync()
    {
        Load();
        await ResolveAccess();
    }

    // The settings URL is guessable, so loading it is an access check: anyone without
    // edit access gets the same "could not be found" card as an unknown id. Within the
    // page, the cards split by role — a collaborator maintains the marketing chrome
    // (header & footer), while site administration (name, publish folders, deploy,
    // people) renders for the OWNER only.
    private async Task ResolveAccess()
    {
        _user = await Access.UserAsync();
        _canAccess = _loadedId is { } id && await Access.CanAccessAsync(id);
        _isOwner = _canAccess && _loadedId is { } ownedId && await Access.IsOwnerAsync(ownedId);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _interactive = true;
            StateHasChanged();
        }
    }

    private void OnSitesChanged() => _ = InvokeAsync(async () =>
    {
        // A rename/environments change elsewhere refreshes our snapshot, but never
        // clobbers in-progress edits: Load only re-seeds when the site identity changes.
        // Access is re-resolved too, so being removed as a collaborator takes effect live.
        _site = _loadedId is { } id ? Sites.Get(id) : null;
        await ResolveAccess();
        StateHasChanged();
    });

    private void Load()
    {
        if (!TryParse(SiteIdValue, out var id))
        {
            _site = null;
            return;
        }

        _site = Sites.Get(id);
        if (_loadedId == id)
        {
            return; // already seeded; keep the user's unsaved edits
        }

        _loadedId = id;
        _name = _site?.Name ?? "";
        SeedEnvs();
        SeedChrome();
    }

    private void SeedEnvs()
    {
        _envs.Clear();
        if (_site is { } site)
        {
            _envs.AddRange(site.Environments.Select(e => new EnvRow { Name = e.Name, Path = e.Path, BaseUrl = e.BaseUrl ?? "" }));
        }
    }

    private int PublishedCount => _site is { } site ? Published.AllForSite(site.Id).Count : 0;

    private bool EnvsDirty =>
        _site is { } site &&
        !_envs.Select(e => (e.Name.Trim(), e.Path.Trim(), e.BaseUrl.Trim()))
            .SequenceEqual(site.Environments.Select(e => (e.Name, e.Path, e.BaseUrl ?? "")));

    private string OpenHref(SiteId id)
    {
        var target = Pages.HomeOf(id) ?? Pages.All(id).FirstOrDefault();
        return target is not null ? $"/edit/{target.Id.Compact}" : $"/sites/{id.Compact}/settings";
    }

    private void AddEnv()
    {
        _envs.Add(new EnvRow());
    }

    private void RemoveEnv(int index)
    {
        _envs.RemoveAt(index);
    }

    private void MoveEnv(int index, int delta)
    {
        var target = index + delta;
        if (target < 0 || target >= _envs.Count)
        {
            return;
        }

        (_envs[index], _envs[target]) = (_envs[target], _envs[index]);
    }

    private async Task SaveName()
    {
        if (_site is not { } site)
        {
            return;
        }

        await Commands.Run(new RenameSite(site.Id, _name.Trim()));
    }

    // ---- Header & footer (marketing chrome) ----

    private readonly ActionEdit _cta = new();
    private readonly ActionEdit _quiet = new();
    private readonly List<NavItemEdit> _navItems = [];
    private readonly List<FooterGroupEdit> _footerGroups = [];
    private string _copyLine = "";
    private LocalizedText? _copyOriginal;

    private Locale ChromeLocale => _site?.DefaultLocale ?? new Locale("en");

    private void SeedChrome()
    {
        SeedAction(_cta, _site?.HeaderCta);
        SeedAction(_quiet, _site?.HeaderQuiet);

        _navItems.Clear();
        foreach (var item in _site?.Navigation ?? [])
        {
            var edit = new NavItemEdit
            {
                Label = item.Label?.Resolve(ChromeLocale, ChromeLocale) ?? "",
                Url = item.Link is { } link ? UrlOf(link) : "",
                OriginalLabel = item.Label,
                OriginalLink = item.Link,
            };
            edit.OriginalUrl = edit.Url;
            foreach (var child in item.Children)
            {
                edit.Children.Add(new NavChildEdit
                {
                    Label = child.Label?.Resolve(ChromeLocale, ChromeLocale) ?? "",
                    Url = UrlOf(child.Link),
                    Description = child.Description?.Resolve(ChromeLocale, ChromeLocale) ?? "",
                    OriginalLabel = child.Label,
                    OriginalDescription = child.Description,
                    OriginalLink = child.Link,
                    OriginalUrl = UrlOf(child.Link),
                });
            }

            _navItems.Add(edit);
        }

        _footerGroups.Clear();
        foreach (var group in _site?.FooterGroups ?? [])
        {
            var edit = new FooterGroupEdit
            {
                Heading = group.Heading.Resolve(ChromeLocale, ChromeLocale),
                OriginalHeading = group.Heading,
            };
            foreach (var link in group.Links)
            {
                edit.Links.Add(new FooterLinkEdit
                {
                    Label = link.Label?.Resolve(ChromeLocale, ChromeLocale) ?? "",
                    Url = UrlOf(link.Link),
                    OriginalLabel = link.Label,
                    OriginalLink = link.Link,
                    OriginalUrl = UrlOf(link.Link),
                });
            }

            _footerGroups.Add(edit);
        }

        _copyOriginal = _site?.CopyLine?.Text;
        _copyLine = _copyOriginal?.Resolve(ChromeLocale, ChromeLocale) ?? "";
    }

    private void SeedAction(ActionEdit edit, HeaderAction? action)
    {
        edit.Label = action?.Label.Resolve(ChromeLocale, ChromeLocale) ?? "";
        edit.Url = action is not null ? UrlOf(action.Link) : "";
        edit.OriginalLabel = action?.Label;
        edit.OriginalLink = action?.Link;
        edit.OriginalUrl = edit.Url;
    }

    private string UrlOf(Link link) => link switch
    {
        ExternalLink external => external.Url,
        PageLink page => $"page://{Pages.Get(page.PageId)?.Slug.Value ?? page.PageId.Compact}",
        _ => "",
    };

    // An untouched URL keeps the original Link exactly; an edited one is page://slug
    // (same-site page, resolved against this site's pages) or an absolute URL.
    private Link? ParseLink(string url, string originalUrl, Link? originalLink, out string? error)
    {
        error = null;
        var trimmed = url.Trim();
        if (trimmed.Length == 0)
        {
            return null;
        }

        if (originalLink is not null && trimmed == originalUrl)
        {
            return originalLink;
        }

        if (trimmed.StartsWith("page://", StringComparison.OrdinalIgnoreCase))
        {
            var slug = trimmed["page://".Length..].Trim('/');
            if (_site is { } site &&
                Pages.All(site.Id).FirstOrDefault(p => string.Equals(p.Slug.Value, slug, StringComparison.OrdinalIgnoreCase)) is { } match)
            {
                return new PageLink(match.Id);
            }

            error = $"No page with slug '{slug}' on this site.";
            return null;
        }

        if (Uri.TryCreate(trimmed, UriKind.Absolute, out var uri) && uri.Scheme is "http" or "https")
        {
            return new ExternalLink(trimmed);
        }

        error = $"'{trimmed}' is not an absolute URL (https://…) or a page://slug link.";
        return null;
    }

    private LocalizedText? Localized(string text, LocalizedText? original) =>
        text.Trim().Length == 0 ? null : (original ?? LocalizedText.Of(ChromeLocale, "")).With(ChromeLocale, text.Trim());

    private void MoveNavItem(int index, int delta)
    {
        var target = index + delta;
        if (target < 0 || target >= _navItems.Count)
        {
            return;
        }

        (_navItems[index], _navItems[target]) = (_navItems[target], _navItems[index]);
    }

    private async Task SaveNavigation()
    {
        if (_site is not { } site)
        {
            return;
        }

        var items = new List<NavigationItem>();
        foreach (var edit in _navItems)
        {
            var label = Localized(edit.Label, edit.OriginalLabel);
            if (edit.Children.Count > 0)
            {
                if (label is null)
                {
                    Toasts.Error("A dropdown group needs a label.");
                    return;
                }

                var children = new List<NavigationChild>();
                foreach (var childEdit in edit.Children)
                {
                    if (childEdit.Label.Trim().Length == 0 && childEdit.Url.Trim().Length == 0)
                    {
                        continue; // an empty row is just an abandoned add
                    }

                    var childLink = ParseLink(childEdit.Url, childEdit.OriginalUrl, childEdit.OriginalLink, out var childError);
                    if (childLink is null)
                    {
                        Toasts.Error($"Menu group '{edit.Label}': {childError ?? "a sub-link needs a target."}");
                        return;
                    }

                    children.Add(new NavigationChild(
                        Localized(childEdit.Label, childEdit.OriginalLabel),
                        childLink,
                        Localized(childEdit.Description, childEdit.OriginalDescription)));
                }

                if (children.Count == 0)
                {
                    Toasts.Error($"The dropdown group '{edit.Label}' needs at least one sub-link.");
                    return;
                }

                items.Add(NavigationItem.Group(label, children));
                continue;
            }

            if (edit.Label.Trim().Length == 0 && edit.Url.Trim().Length == 0)
            {
                continue; // an empty row is just an abandoned add
            }

            var link = ParseLink(edit.Url, edit.OriginalUrl, edit.OriginalLink, out var error);
            if (link is null)
            {
                Toasts.Error($"Menu: {error ?? $"'{edit.Label}' needs a target (or sub-links to become a dropdown)."}");
                return;
            }

            items.Add(new NavigationItem { Label = label, Link = link });
        }

        if (await Commands.Run(new ChangeNavigation(site.Id, items)))
        {
            _site = Sites.Get(site.Id);
            SeedChrome();
            Toasts.Show("Navigation saved.");
        }
    }

    private bool BuildAction(ActionEdit edit, string what, out HeaderAction? action)
    {
        action = null;
        var hasLabel = edit.Label.Trim().Length > 0;
        var hasUrl = edit.Url.Trim().Length > 0;
        if (!hasLabel && !hasUrl)
        {
            return true; // cleared
        }

        if (!hasLabel || !hasUrl)
        {
            Toasts.Error($"The {what} needs both a label and a link (clear both to remove it).");
            return false;
        }

        var link = ParseLink(edit.Url, edit.OriginalUrl, edit.OriginalLink, out var error);
        if (link is null)
        {
            Toasts.Error($"{what}: {error}");
            return false;
        }

        action = new HeaderAction(Localized(edit.Label, edit.OriginalLabel)!, link);
        return true;
    }

    private async Task SaveHeader()
    {
        if (_site is not { } site ||
            !BuildAction(_cta, "primary button", out var cta) ||
            !BuildAction(_quiet, "quiet link", out var quiet))
        {
            return;
        }

        if (await Commands.Run(new SetHeaderActions(site.Id, cta, quiet)))
        {
            _site = Sites.Get(site.Id);
            SeedChrome();
            Toasts.Show("Header saved.");
        }
    }

    private async Task SaveFooter()
    {
        if (_site is not { } site)
        {
            return;
        }

        var groups = new List<FooterLinkGroup>();
        foreach (var edit in _footerGroups)
        {
            var links = new List<FooterLink>();
            foreach (var linkEdit in edit.Links)
            {
                if (linkEdit.Label.Trim().Length == 0 && linkEdit.Url.Trim().Length == 0)
                {
                    continue; // an empty row is just an abandoned add
                }

                var link = ParseLink(linkEdit.Url, linkEdit.OriginalUrl, linkEdit.OriginalLink, out var error);
                if (link is null)
                {
                    Toasts.Error($"Footer: {error ?? "a link needs a target."}");
                    return;
                }

                links.Add(new FooterLink(Localized(linkEdit.Label, linkEdit.OriginalLabel), link));
            }

            if (edit.Heading.Trim().Length == 0 && links.Count == 0)
            {
                continue; // an empty column is just an abandoned add
            }

            groups.Add(new FooterLinkGroup(
                Localized(edit.Heading, edit.OriginalHeading) ?? LocalizedText.Of(ChromeLocale, ""),
                links));
        }

        if (await Commands.Run(new SetFooter(site.Id, groups)))
        {
            _site = Sites.Get(site.Id);
            SeedChrome();
            Toasts.Show("Footer saved.");
        }
    }


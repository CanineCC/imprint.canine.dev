@using Imprint.Editor.Services
@implements IDisposable
@inject ToastService Toasts

<div class="ed-toast-host" aria-live="polite">
    @foreach (var entry in _visible)
    {
        <div class="ed-toast @(entry.Toast.IsError ? "ed-toast-error" : null)" role="status">
            <span>@entry.Toast.Message</span>
            @if (entry.Toast.UndoAction is { } undo)
            {
                <button type="button" class="ed-btn ed-btn-ghost" @onclick="() => RunUndo(entry, undo)">
                    @entry.Toast.UndoLabel
                </button>
            }
            <button type="button" class="ed-btn ed-btn-ghost" aria-label="Dismiss" @onclick="() => Dismiss(entry)">✕</button>
        </div>
    }
</div>

@code {
    private sealed record Entry(Toast Toast, DateTimeOffset ShownAt);

    private readonly List<Entry> _visible = [];

    protected override void OnInitialized() => Toasts.Shown += OnToast;

    private void OnToast(Toast toast) => _ = InvokeAsync(async () =>
    {
        var entry = new Entry(toast, DateTimeOffset.UtcNow);
        _visible.Add(entry);
        StateHasChanged();

        // Errors stay until dismissed; confirmations (and their undo window) fade.
        if (!toast.IsError)
        {
            await Task.Delay(TimeSpan.FromSeconds(5));
            Dismiss(entry);
        }
    });

    private async Task RunUndo(Entry entry, Func<Task> undo)
    {
        Dismiss(entry);
        await undo();
    }

    private void Dismiss(Entry entry)
    {
        if (_visible.Remove(entry))
        {
            StateHasChanged();
        }
    }

    public void Dispose() => Toasts.Shown -= OnToast;
}

@using Imprint.Authoring.Projections
@using Imprint.Editor.Auth
@using Imprint.Editor.Services
@using Microsoft.Extensions.Configuration
@implements IDisposable
@inject EditorSession Session
@inject SiteOverview Site
@inject PageList Pages
@inject CommandRunner Commands
@inject ToastService Toasts
@inject IConfiguration Config
@inject KeycloakOptions Auth

@* The frame: top bar, icon rail, contextual left panel, canvas column, inspector,
   status bar, toast host. Panels own their interiors; the shell owns arrangement. *@

<div class="ed-app">
    <header class="ed-topbar">
        <a class="ed-btn ed-btn-ghost ed-back" href="/" title="All sites" aria-label="Back to all sites">←</a>
        <span class="ed-site-name">@(Session.ActiveSite?.Name ?? "Imprint")</span>
        @if (Session.ActiveSiteId is { } activeId)
        {
            <a class="ed-btn ed-btn-ghost ed-gear" href="@($"/sites/{activeId.Compact}/settings")"
               title="Site settings &amp; publishing" aria-label="Site settings and publishing">⚙</a>
        }
        <TopBarPageSwitcher />
        <span style="flex:1"></span>
        <ViewportToggle />
        <LocaleSwitcher />
        <button type="button" class="ed-btn ed-btn-ghost" title="Preview site dark mode"
                aria-label="Toggle canvas dark mode" @onclick="Session.ToggleCanvasDark">
            @(Session.CanvasDark ? "☾" : "☀")
        </button>
        @if (PreviewHref is { } previewHref)
        {
            <a class="ed-btn ed-btn-ghost" href="@previewHref" target="_blank" rel="noopener"
               title="Open the published site in a new tab — no editor chrome, fully navigable, not deployed"
               aria-label="Open preview in a new tab">Preview&nbsp;↗</a>
        }
        <PublishButton />
        @if (Auth.Enabled)
        {
            <form class="ed-signout" method="post" action="/auth/logout">
                <button type="submit" class="ed-btn ed-btn-ghost" title="Sign out" aria-label="Sign out">⎋</button>
            </form>
        }
    </header>

    <nav class="ed-rail" aria-label="Editor panels">
        @foreach (var (panel, icon, label) in Rail)
        {
            <button type="button"
                    class="ed-btn ed-btn-ghost ed-rail-btn"
                    aria-label="@label"
                    title="@label"
                    aria-pressed="@(Session.Panel == panel && !Session.PanelCollapsed)"
                    @onclick="() => Session.ShowPanel(panel)">@icon</button>
        }
    </nav>

    <aside class="ed-panel" hidden="@Session.PanelCollapsed" aria-label="@Session.Panel panel">
        @switch (Session.Panel)
        {
            case EditorPanel.Pages: <PagesPanel /> break;
            case EditorPanel.Layers: <LayersPanel /> break;
            case EditorPanel.Blocks: <BlocksPanel /> break;
            case EditorPanel.Assets: <AssetsPanel /> break;
            case EditorPanel.Theme: <ThemePanel /> break;
            case EditorPanel.Translations: <TranslationsPanel /> break;
        }
    </aside>

    <section class="ed-canvas-area">
        <BreadcrumbBar />
        <Canvas />
        <NodeToolbar />
        <InsertPicker />
    </section>

    <aside class="ed-inspector" aria-label="Inspector">
        <InspectorPanel />
    </aside>

    <footer class="ed-statusbar">
        <span>All changes saved</span>
        <PublishStatus />
        @if (Commands.CanUndo)
        {
            <span class="ed-undo-hint">Ctrl+Z undoes @Commands.UndoLabel</span>
        }
        <span style="flex:1"></span>
        @if (AdminEnabled)
        {
            @* Admin review surface. Authorization is the reverse proxy's job (see
               architecture.md non-goals): this route MUST sit behind your auth. *@
            <a class="ed-admin-link" href="/admin/widgets"
               title="Widget review — put this route behind your reverse-proxy auth">Widgets</a>
        }
    </footer>

    @* ToastHost renders once in MainLayout — a second host here would double every toast. *@
</div>

@code {
    private static readonly (EditorPanel Panel, string Icon, string Label)[] Rail =
    [
        (EditorPanel.Pages, "▤", "Pages"),
        (EditorPanel.Layers, "≡", "Layers"),
        (EditorPanel.Blocks, "▦", "Blocks"),
        (EditorPanel.Assets, "🖼", "Assets"),
        (EditorPanel.Theme, "◐", "Theme"),
        (EditorPanel.Translations, "文", "Translations"),
    ];

    // The reachable published-style preview (/preview/{site}) of the active site, at the
    // open page when that page has been published, else the site root. The preview plane
    // resolves a site by slug OR compact id — the id is the stable choice here.
    private string? PreviewHref
    {
        get
        {
            if (Session.ActiveSiteId is not { } siteId)
            {
                return null;
            }

            var root = $"/preview/{siteId.Compact}/";
            return Session.CurrentPageId is { } pageId
                   && Pages.Get(pageId) is { PublishedVersion: not null, IsHome: false } page
                ? $"{root}{page.Slug.Value}/"
                : root;
        }
    }

    // Gate for the /admin/widgets link (and the page itself). Default on for the demo;
    // set ImprintAdmin=false to hide it. This is a visibility gate, not access control —
    // the route must still be protected by your reverse proxy.
    private bool AdminEnabled => Config.GetValue("ImprintAdmin", true);

    protected override void OnInitialized()
    {
        Session.Changed += Refresh;
        Commands.Changed += Refresh;
        Site.Changed += Refresh;
    }

    private void Refresh() => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Session.Changed -= Refresh;
        Commands.Changed -= Refresh;
        Site.Changed -= Refresh;
    }
}

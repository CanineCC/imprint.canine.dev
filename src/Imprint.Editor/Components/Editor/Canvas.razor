@using Imprint.Authoring.Projections
@using Imprint.Editor.Services
@using Imprint.Rendering
@implements IAsyncDisposable
@inject EditorSession Session
@inject CanvasBridge Bridge
@inject PageDrafts Drafts
@inject SiteOverview Site
@inject EditorRenderContextFactory ContextFactory
@inject IJSRuntime Js

@* The canvas: the page rendered by the SAME components the publisher uses, wrapped in
   the interaction overlay (canvas-interop.js draws outlines/indicators; Blazor renders
   nothing decorative here). Clicks are suppressed so preview links never navigate. *@

<div class="ed-canvas-scroll" @ref="_scroller" tabindex="0">
    <div class="ed-canvas-frame" style="--ed-canvas-width: @Session.ViewportWidth">
        @if (Session.ActiveSite is { } site && Session.CurrentPage is { } page)
        {
            <style>@((MarkupString)ThemeCss.EmitScoped(site.Theme, ".ed-canvas"))</style>
            <div class="ed-canvas"
                 data-theme="@(Session.CanvasDark ? "dark" : "light")"
                 @ref="_canvas"
                 @onclick="() => { }"
                 @onclick:preventDefault>
                <CascadingValue Value="Context">
                    <PageView Roots="page.Tree.Roots" />
                </CascadingValue>
            </div>
            <div class="ed-overlay" @ref="_overlay"></div>
        }
    </div>
</div>

@code {
    private ElementReference _scroller;
    private ElementReference _canvas;
    private ElementReference _overlay;
    private IJSObjectReference? _module;
    private DotNetObjectReference<CanvasBridge>? _bridgeRef;
    private NodeId? _lastSentSelection;
    private bool _interopReady;

    private RenderContext Context => ContextFactory.For(Session.EditLocale, Session.ActiveSite?.DefaultLocale);

    protected override void OnInitialized()
    {
        Session.Changed += OnStateChanged;
        Drafts.Changed += OnStateChanged;
        // Theme edits live on the site stream: without this the theme panel's
        // changes only appear after the next page edit repaints the canvas.
        Site.Changed += OnStateChanged;
        Bridge.EnterInlineEditInJs = async (nodeId, mode) =>
        {
            if (_module is not null)
            {
                await _module.InvokeVoidAsync("enterInlineEdit", nodeId, mode);
            }
        };
    }

    private void OnStateChanged()
    {
        // While a contenteditable is live, Blazor must not patch the canvas out from
        // under the caret — the session's edit flag gates every re-render.
        _ = InvokeAsync(() =>
        {
            if (Session.EditingNodeId is null)
            {
                StateHasChanged();
            }
        });
    }

    protected override bool ShouldRender() => Session.EditingNodeId is null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Session.CurrentPage is null)
        {
            return;
        }

        if (!_interopReady)
        {
            _interopReady = true;
            _bridgeRef = DotNetObjectReference.Create(Bridge);
            await Js.InvokeAsync<IJSObjectReference>("import", "./js/rich-toolbar.js");
            _module = await Js.InvokeAsync<IJSObjectReference>("import", "./js/canvas-interop.js");
            await _module.InvokeVoidAsync("init", _canvas, _overlay, _scroller, _bridgeRef);
        }

        if (_module is not null && _lastSentSelection != Session.Selection)
        {
            _lastSentSelection = Session.Selection;
            await _module.InvokeVoidAsync("setSelection", Session.Selection?.Compact);
        }
    }

    public async ValueTask DisposeAsync()
    {
        Session.Changed -= OnStateChanged;
        Drafts.Changed -= OnStateChanged;
        Site.Changed -= OnStateChanged;
        Bridge.EnterInlineEditInJs = null;
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose");
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // circuit already gone — nothing to clean on the client
            }
        }

        _bridgeRef?.Dispose();
    }
}

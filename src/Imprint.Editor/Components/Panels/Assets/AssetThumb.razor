@* A small preview square: the smallest generated variant for images, a kind glyph for
   everything else (docs/editor-ux.md §7 — Assets). Shared by the panel and the picker.
   Dark="true" previews the asset's dark-mode variant instead of the base rendition. *@
@using Imprint.Authoring.Domain.Assets

<span class="asset-thumb">
    @{ var variants = Dark ? Asset.DarkVariants : Asset.Variants; }
    @if (Asset.Kind == AssetKind.Image && variants.Count > 0)
    {
        <img src="@($"/media/{variants[0].StorageKey}")" alt="" loading="lazy" />
    }
    else
    {
        <span class="asset-glyph" aria-hidden="true">@AssetUi.Glyph(Asset.Kind)</span>
    }
</span>

@code {
    [Parameter, EditorRequired] public Asset Asset { get; set; } = null!;

    /// <summary>Preview the dark-mode variant (its smallest rendition) rather than the base.</summary>
    [Parameter] public bool Dark { get; set; }
}

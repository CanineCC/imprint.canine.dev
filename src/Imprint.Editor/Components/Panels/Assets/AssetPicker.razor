@* Select mode for assets: a self-contained, embeddable picker. The Inspector hosts it
   for image/video/graphic props — filter by Kind, get the chosen id via OnPicked. *@
@using Imprint.Authoring.Domain.Assets
@using Imprint.Authoring.Projections
@implements IDisposable
@inject AssetLibrary Library

<link rel="stylesheet" href="Imprint.Editor.styles.css" />

<div class="asset-picker">
    <input class="ed-input" placeholder="Search assets…" aria-label="Search assets"
           value="@_query"
           @oninput="args => _query = args.Value?.ToString() ?? string.Empty" />

    @{ var matches = Matching(); }
    @if (matches.Count == 0)
    {
        <p class="picker-empty">
            @if (_query.Trim().Length > 0)
            {
                <text>Nothing matches “@_query”.</text>
            }
            else if (Kind is { } kind)
            {
                <text>No @AssetUi.KindLabel(kind).ToLowerInvariant() files yet — upload one in the Assets panel.</text>
            }
            else
            {
                <text>No assets yet — upload one in the Assets panel.</text>
            }
        </p>
    }
    else
    {
        <div class="picker-grid" role="listbox" aria-label="Pick an asset">
            @foreach (var asset in matches)
            {
                <button type="button" role="option" aria-selected="false" class="picker-item"
                        title="@asset.Name"
                        @onclick="() => OnPicked.InvokeAsync(asset.Id)">
                    <AssetThumb Asset="asset" />
                    <span class="picker-name">@asset.Name</span>
                </button>
            }
        </div>
    }
</div>

@code {
    /// <summary>Limits the choices to one kind (image, video, …); null shows everything.</summary>
    [Parameter] public AssetKind? Kind { get; set; }

    /// <summary>Raised with the chosen asset's id; the host closes the picker.</summary>
    [Parameter] public EventCallback<AssetId> OnPicked { get; set; }

    private string _query = "";

    protected override void OnInitialized() => Library.Changed += Refresh;

    private void Refresh() => _ = InvokeAsync(StateHasChanged);

    private List<Asset> Matching()
    {
        var query = _query.Trim();
        return
        [
            .. Library.All()
                .Where(asset => Kind is not { } kind || asset.Kind == kind)
                .Where(asset => asset.Status != AssetStatus.Failed)
                .Where(asset => query.Length == 0 ||
                    asset.Name.Contains(query, StringComparison.OrdinalIgnoreCase)),
        ];
    }

    public void Dispose() => Library.Changed -= Refresh;
}

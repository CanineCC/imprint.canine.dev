@* One page in the panel list: title + address open the editor, the badge tells the
   publish story. Navigation membership lives in the settings menu editor, not here. *@
@using Imprint.Authoring.Projections
@using Imprint.Editor.Services
@inject EditorSession Session
@inject SiteOverview Site
@inject NavigationManager Navigation

<li class="page-row">
    <button type="button" class="page-open"
            aria-current="@(Session.CurrentPageId == Entry.Id ? "page" : null)"
            @onclick="Open">
        <span class="page-title">@Title</span>
        <span class="page-slug">@PathText</span>
    </button>
    <span class="ed-badge @BadgeClass">@Entry.Status</span>
</li>

@code {
    [Parameter, EditorRequired] public PageSummary Entry { get; set; } = null!;

    private string Title
    {
        get
        {
            var fallback = Session.ActiveSite?.DefaultLocale ?? Session.EditLocale;
            var title = Entry.Title.Resolve(Session.EditLocale, fallback);
            return title.Length > 0 ? title : "(untitled)";
        }
    }

    private string PathText => Entry.IsHome ? "/" : $"/{Entry.Slug.Value}/";

    private string BadgeClass => Entry.Status switch
    {
        PageStatus.Draft => "ed-badge-warn",
        PageStatus.Modified => "ed-badge-accent",
        _ => "ed-badge-ok",
    };

    private void Open() => Navigation.NavigateTo($"/edit/{Entry.Id.Compact}");
}

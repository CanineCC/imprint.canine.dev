@* The site's languages: list, add (validated live), remove and change the default.
   Domain guards (default removal, duplicates, the 10-locale cap) speak via toasts.
   The host passes the Site to manage (the settings page's site); without one it falls
   back to the session's active site — never silently the FIRST site, which on a
   multi-site install would edit someone else's locales. *@
@using Imprint.Authoring.Projections
@using Imprint.Editor.Services
@implements IDisposable
@inject SiteOverview Overview
@inject EditorSession Session
@inject CommandRunner Commands

@if (Target is { } site)
{
    <section class="locale-manager">
        <ul class="locale-list">
            @foreach (var locale in site.Locales)
            {
                var value = locale.Value;
                <li class="locale-row">
                    <span class="locale-tag">@value</span>
                    @if (locale == site.DefaultLocale)
                    {
                        <span class="ed-badge ed-badge-accent">Default</span>
                    }
                    else
                    {
                        <button type="button" class="ed-btn ed-btn-ghost locale-action"
                                @onclick="() => MakeDefault(value)">Make default</button>
                        <button type="button" class="ed-btn ed-btn-ghost ed-btn-danger locale-action"
                                title="Remove @value" aria-label="Remove @value"
                                @onclick="() => Remove(value)">✕</button>
                    }
                </li>
            }
        </ul>
        <div class="locale-add">
            <label class="ed-visually-hidden" for="pp-add-locale">Add a language</label>
            <input id="pp-add-locale" class="ed-input" placeholder="Add a language (en, da, de-AT)"
                   @bind="_input" @bind:event="oninput" @onkeydown="OnKey" />
            <button type="button" class="ed-btn" disabled="@(_input.Trim().Length == 0)"
                    @onclick="Add">Add</button>
        </div>
        @if (_hint is { } hint)
        {
            <p class="locale-hint">@hint</p>
        }
    </section>
}

@code {
    /// <summary>The site whose languages are managed. Optional: an editor-chrome host may
    /// omit it, in which case the session's active site (the open page's site) is used.</summary>
    [Parameter] public Site? Site { get; set; }

    private string _input = "";
    private string? _hint;

    private Site? Target => Site ?? Session.ActiveSite;

    protected override void OnInitialized() => Overview.Changed += Refresh;

    private void Refresh() => _ = InvokeAsync(StateHasChanged);

    private async Task Add()
    {
        if (Target is not { } site)
        {
            return;
        }

        var candidate = _input.Trim();
        if (candidate.Length == 0)
        {
            return;
        }

        if (!Locale.TryCreate(candidate, out var locale))
        {
            _hint = $"'{candidate}' does not look like a language code. Try 'en', 'da' or 'de-AT'.";
            return;
        }

        _hint = null;
        if (await Commands.Run(
                new Authoring.Features.Sites.AddLocale.AddLocale(site.Id, locale.Value),
                new Authoring.Features.Sites.RemoveLocale.RemoveLocale(site.Id, locale.Value),
                "language addition"))
        {
            _input = "";
        }
    }

    private async Task OnKey(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await Add();
        }
    }

    private async Task MakeDefault(string value)
    {
        if (Target is not { } site)
        {
            return;
        }

        await Commands.Run(
            new Authoring.Features.Sites.ChangeDefaultLocale.ChangeDefaultLocale(site.Id, value),
            new Authoring.Features.Sites.ChangeDefaultLocale.ChangeDefaultLocale(site.Id, site.DefaultLocale.Value),
            "default language change");
    }

    private async Task Remove(string value)
    {
        if (Target is not { } site)
        {
            return;
        }

        await Commands.Run(
            new Authoring.Features.Sites.RemoveLocale.RemoveLocale(site.Id, value),
            new Authoring.Features.Sites.AddLocale.AddLocale(site.Id, value),
            "language removal");
    }

    public void Dispose() => Overview.Changed -= Refresh;
}
